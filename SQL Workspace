-- 4. Which genre has the highest and lowest daily listening time?
select max(daily_listening_minutes) as max_daily_listening_minutes, top_genre
from `Musichabits.Music `
group by top_genre
-- The Hip-Hop genre has the highest daily listening time

-- 5. Which country has the highest and lowest listening time?
select max(daily_listening_minutes) as max_daily_listening_minutes, min (daily_listening_minutes) as min_daily_listening_minutes, country
from `Musichabits.Music `
group by country
order by country asc;
-- United Kingdom has the highest listening time
-- Brazil has the lowest listening time 

-- 6. Can we combine genre and mood into a single “content preference” category to see which combinations are most common? Give me the top five?
select top_genre, top_mood, count(*) as Content_Preference
from `Musichabits.Music `
group by top_genre, top_mood
having Content_Preference > 1
order by Content_Preference desc
limit 5;
-- By looking at the data we can see that top genre (POP) and top mood (HAPPY) are the most common combination along with the others 

-- 7. -- How can we create a listener profile label that combines each user’s subscription type, favorite genre, and listening mood into one customer segment description?
select listener_id,
  concat(subscription, ' - ', top_genre, ' - ', top_mood) as listener_profile_label
from `Musichabits.Music `

-- 8. Which platform has the most total daily listening?
select platform, sum(daily_listening_minutes) as total_daily_listening_minutes
from `Musichabits`.`Music `
group by platform
order by sum(daily_listening_minutes) desc
-- The platform with the most total daily listening is Spotify

-- 9. How many users are on each subscription plan?
select subscription, count(listener_id) as user_count
from `Musichabits.Music `
group by subscription
-- The free subscription has the most users, as the student subsription has the least users 


-- Dashboard 2
-- 10. Who is the top artist that the users listen to?
select top_artist, count(listener_id) as user_count
from `Musichabits.Music `
group by top_artist
having user_count > 1
order by user_count desc
-- Olivia Rodrigo is the #1 artist that the users are listening to

-- 11. What artist has the lowest listners from users 
select top_artist, count(listener_id) as user_count
from `Musichabits.Music `
group by top_artist
having user_count > 1
order by user_count asc
-- Ariana Grande has the lowest listening count from users
