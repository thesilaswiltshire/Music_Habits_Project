SELECT age, platform, daily_listening_minutes, songs_per_day
FROM `musichabits-501505.Musichabits.Music ` as Music
limit 10;

-- Dashboard 1
-- 1. Which subscription type (Free, Premium, Student, Family) has the highest average daily listening time, and what does that tell us about customer value?
select subscription, avg (daily_listening_minutes) as avg_daily_listening_minutes
from `Musichabits.Music `
group by subscription
order by avg_daily_listening_minutes desc;
-- The student subscription has the highest average daily listening time 

-- 2. Do users who use Discover Weekly listen listen to music longer, skip fewer songs, or create more playlists than users who don't use it 
select discover_weekly_user, avg(daily_listening_minutes) as avg_daily_listening_users, avg(skip_rate_pct) as avg_skip_rate, avg(playlists_count) as avg_playlist_count
from `Musichabits.Music `
group by discover_weekly_user
-- True: users who use dicover weekly average less daily listening, skip more songs, and have a higher playlist count
-- False: users who don't use discover weekly average more daily listening, skip less songs, and have lower playlist count 

